# Copy to .env and fill in values. Never commit .env.

ENVIRONMENT=development

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neco
REDIS_URL=redis://localhost:6379/0

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Anthropic (required for full analysis features)
ANTHROPIC_API_KEY=

# --- Clerk JWT (required for any non-local ENVIRONMENT) ---
# Local: ENVIRONMENT=development|dev|local may use CLERK_JWT_VERIFY=false (warning logged).
# Staging/production/demo: set all of the following.
# CLERK_JWKS_URL=https://YOUR_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWT_VERIFY=true
# CLERK_JWT_ISSUER=https://YOUR_INSTANCE.clerk.accounts.dev
# CLERK_JWT_AUDIENCE=  # optional; set if you verify audience (multi-app Clerk)

SPRINT12_DEV_AUTO_PROVISION=False
