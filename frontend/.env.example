# Copy to .env.local and adjust. Never commit .env.local.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Must match the origin where the FastAPI app listens (see start_neco.sh / docker compose).
NEXT_PUBLIC_API_URL=http://localhost:9001

# Local dev: bypass Clerk; use /dev-login
NEXT_PUBLIC_DEV_AUTH=false

# Optional: when not using Clerk org in dev
# NEXT_PUBLIC_TEST_ORG_ID=

# Optional: same-origin API via Next rewrite
# NEXT_PUBLIC_USE_API_PROXY=false
